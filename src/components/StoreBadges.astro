---
import { SITE } from '../data/content';

interface Props {
  showHint?: boolean;
  centered?: boolean;
}

const { showHint = true, centered = true } = Astro.props;
---

<div class:list={['store-badges-wrap', { 'store-badges-wrap--center': centered }]}>
  {showHint && (
    <p class="store-badges__hint">
      Get started at <a href={SITE.appWebUrl} class="store-badges__web-link">{SITE.appWebUrl.replace('https://', '')}</a>
      — or download from your store below.
    </p>
  )}
  <div class="store-badges">
    <a href={SITE.appWebUrl} class="store-badge store-badge--web js-app-link" data-play-store={SITE.playStore} data-app-web={SITE.appWebUrl}>
      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14H9V8h2v8zm4 0h-2V8h2v8z" fill="currentColor"/></svg>
      <span class="store-badge__text"><small>Open web app</small><strong>app.scan-perks.com</strong></span>
    </a>
    <a href={SITE.playStore} class="store-badge" rel="noopener noreferrer">
      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3.609 1.814L13.792 12 3.61 22.186a1.372 1.372 0 01-.181-.698V2.512c0-.26.065-.507.18-.698zm1.37 20.127L15.35 14.1l-3.064-3.064L4.98 21.94zM16.81 13.06l2.966 1.71c.955.553.955 1.937 0 2.49l-2.966 1.71-3.3-3.3 3.3-3.3zM15.35 9.9L4.98 2.06l7.306 10.904L15.35 9.9z"/></svg>
      <span class="store-badge__text"><small>Get it on</small><strong>Google Play</strong></span>
    </a>
    <a href={SITE.appStore} class="store-badge" rel="noopener noreferrer">
      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
      <span class="store-badge__text"><small>Download on the</small><strong>App Store</strong></span>
    </a>
  </div>
</div>
