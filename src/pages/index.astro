---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import KeywordMarquee from '../components/KeywordMarquee.astro';
import SeoQuerySection from '../components/SeoQuerySection.astro';
import FAQSection from '../components/FAQSection.astro';
import AppCta from '../components/AppCta.astro';
import StoreBadges from '../components/StoreBadges.astro';
import { landingContent } from '../data/content';
import { buildSoftwareApplicationSchema } from '../seo/schema';

const c = landingContent;
const loyaltyQueries = c.seoQueries.slice(0, 12);
const growthQueries = c.seoQueries.slice(12);
---

<BaseLayout
  title={c.metaTitle}
  description={c.metaDescription}
  path="/"
  keywords={c.metaKeywords}
  faqs={c.faqs}
  extraSchema={[buildSoftwareApplicationSchema()]}
>
  <Nav active="home" />

  <section class="hero">
    <div class="container">
      <div class="hero__content">
        <div>
          <div class="hero__badge">
            <span class="hero__badge-dot"></span>
            Business Loyalty Program
          </div>
          <h1 class="hero__title">{c.heroTitle}</h1>
          <p class="hero__seo-line">{c.heroSeoLine}</p>
          <p class="hero__desc">{c.heroDescription}</p>
          <div class="hero__actions">
            <AppCta class="btn btn--primary btn--lg">Start Free Trial</AppCta>
            <a href="/business-loyalty-program/" class="btn btn--glass btn--lg">Loyalty Guide</a>
          </div>
          <div class="hero__stats">
            <div>
              <div class="hero__stat-value">500+</div>
              <div class="hero__stat-label">Businesses</div>
            </div>
            <div>
              <div class="hero__stat-value">50K+</div>
              <div class="hero__stat-label">Active Users</div>
            </div>
            <div>
              <div class="hero__stat-value">14 Days</div>
              <div class="hero__stat-label">Free Trial</div>
            </div>
          </div>
        </div>
        <div class="hero__visual">
          <div class="hero__phone">
            <div class="hero__phone-screen">
              <div class="hero__qr" aria-hidden="true">
                {Array.from({ length: 25 }).map(() => <span></span>)}
              </div>
              <p class="hero__phone-text">Scan to earn rewards — bar & restaurant loyal customers</p>
            </div>
          </div>
          <div class="hero__float-card glass glass--strong hero__float-card--1">+24% repeat visits</div>
          <div class="hero__float-card glass glass--strong hero__float-card--2">Reward unlocked!</div>
        </div>
      </div>
    </div>
  </section>

  <KeywordMarquee keywords={c.keywordMarquee} />

  <section class="section">
    <div class="container">
      <div class="section__header reveal">
        <span class="section__label">Grow Your Business</span>
        <h2 class="section__title">Loyalty Programs for Every Venue</h2>
        <p class="section__subtitle">Dedicated solutions to get bar loyal customers, restaurant loyal customers, and cafe regulars — all from one platform.</p>
      </div>
      <div class="features-grid">
        <a href="/bar-loyalty-program/" class="glass-card reveal" style="display:block;">
          <div class="feature-card__icon">🍺</div>
          <h3 class="feature-card__title">Bar Loyalty Program</h3>
          <p class="feature-card__desc">Happy-hour pushes, free-drink tiers, and repeat visit tracking for pubs and bars.</p>
        </a>
        <a href="/restaurant-loyalty-program/" class="glass-card reveal" style="display:block;">
          <div class="feature-card__icon">🍽️</div>
          <h3 class="feature-card__title">Restaurant Loyalty Program</h3>
          <p class="feature-card__desc">Retain diners with tiered rewards, analytics, and slow-night campaigns.</p>
        </a>
        <a href="/cafe-loyalty-program/" class="glass-card reveal" style="display:block;">
          <div class="feature-card__icon">☕</div>
          <h3 class="feature-card__title">Cafe Loyalty Program</h3>
          <p class="feature-card__desc">Digital stamp cards and counter QR for coffee shops and bakeries.</p>
        </a>
        <a href="/qr-loyalty-program/" class="glass-card reveal" style="display:block;">
          <div class="feature-card__icon">📱</div>
          <h3 class="feature-card__title">QR Code Loyalty</h3>
          <p class="feature-card__desc">Replace punch cards with smartphone scanning and full visit data.</p>
        </a>
        <a href="/grow-restaurant-business/" class="glass-card reveal" style="display:block;">
          <div class="feature-card__icon">📈</div>
          <h3 class="feature-card__title">Grow Restaurant Business</h3>
          <p class="feature-card__desc">Use loyalty as a growth engine — more repeat customers, higher lifetime value.</p>
        </a>
        <a href="/business-loyalty-program/" class="glass-card reveal" style="display:block;">
          <div class="feature-card__icon">📘</div>
          <h3 class="feature-card__title">Business Loyalty Guide</h3>
          <p class="feature-card__desc">Complete encyclopedia: what is a business loyalty program and how to start.</p>
        </a>
      </div>
    </div>
  </section>

  <SeoQuerySection
    queries={loyaltyQueries}
    title="Business Loyalty — Quick Answers"
    subtitle="Common questions about loyalty programs, QR rewards, and repeat customers."
  />

  <SeoQuerySection
    queries={growthQueries}
    title="Grow Customers, Trust & Profits"
    subtitle="How Scan Perks helps you increase customers, build credibility, and boost restaurant revenue."
  />

  <section class="section section--sm">
    <div class="container">
      <div class="section__header reveal">
        <span class="section__label">How It Works</span>
        <h2 class="section__title">Launch Your Loyalty Program in Minutes</h2>
      </div>
      <div class="steps">
        <div class="glass-card step reveal">
          <h3 class="step__title">Sign Up</h3>
          <p class="step__desc">Create your business account in under 5 minutes. 14-day free trial.</p>
        </div>
        <div class="glass-card step reveal">
          <h3 class="step__title">Set Rewards</h3>
          <p class="step__desc">Design perks for bar loyal customers or restaurant regulars.</p>
        </div>
        <div class="glass-card step reveal">
          <h3 class="step__title">Display QR</h3>
          <p class="step__desc">Print your code and place it at the counter or tables.</p>
        </div>
        <div class="glass-card step reveal">
          <h3 class="step__title">Grow Loyalty</h3>
          <p class="step__desc">Track visits, send push offers, and grow your business.</p>
        </div>
      </div>
    </div>
  </section>

  <FAQSection faqs={c.faqs} />

  <section class="section section--sm">
    <div class="container reveal">
      <div class="cta-banner">
        <h2 class="cta-banner__title">Grow Loyal Customers Starting Today</h2>
        <p class="cta-banner__desc">Business loyalty program from $10/month. 14-day free trial for bars, cafes & restaurants.</p>
        <div class="cta-banner__actions">
          <StoreBadges />
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  .hero__seo-line {
    font-size: 1.1rem;
    color: var(--blue-300);
    margin-bottom: 1rem;
    line-height: 1.6;
    font-weight: 500;
  }
</style>
