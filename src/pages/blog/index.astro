---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { blogArticles } from '../../data/blogArticles';
---

<BaseLayout
  title="Blog — Business Loyalty Tips for Bars & Restaurants | Scan Perks"
  description="Expert guides on business loyalty programs, restaurant loyal customers, bar retention, and QR rewards. Grow your business with Scan Perks blog."
  path="/blog/"
  breadcrumbs={[{ name: 'Home', path: '/' }, { name: 'Blog', path: '/blog/' }]}
>
  <Nav active="blog" />

  <section class="page-hero">
    <div class="container reveal">
      <span class="section__label">Blog</span>
      <h1 class="page-hero__title">Grow Your Business with <span class="gradient-text">Loyalty Insights</span></h1>
      <p class="page-hero__desc">Guides on bar loyal customers, restaurant retention, and affordable loyalty programs.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="features-grid">
        {blogArticles.map((article) => (
          <a href={`/blog/${article.slug}/`} class="glass-card reveal" style="display:block;">
            <p class="blog-card__date">{article.publishedAt}</p>
            <h2 class="feature-card__title">{article.title}</h2>
            <p class="feature-card__desc">{article.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
