---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout
  title="About Scan Perks — Hospitality Loyalty Platform"
  description="Scan Perks helps bars, cafes & restaurants grow loyal customers with affordable QR-based business loyalty programs. Founded to democratize hospitality loyalty."
  path="/about/"
  breadcrumbs={[{ name: 'Home', path: '/' }, { name: 'About', path: '/about/' }]}
>
  <Nav active="about" />

  <section class="page-hero">
    <div class="container reveal">
      <span class="section__label">About</span>
      <h1 class="page-hero__title">Loyalty Built for <span class="gradient-text">Hospitality</span></h1>
      <p class="page-hero__desc">We believe every bar, cafe, and restaurant deserves enterprise-quality loyalty tools at an independent-venue price.</p>
    </div>
  </section>

  <section class="section section--sm">
    <div class="container">
      <div class="about-grid">
        <div class="reveal">
          <h2 class="section__title" style="text-align:left; font-size:1.75rem; margin-bottom:1rem;">Our Mission</h2>
          <p style="color:var(--text-secondary); line-height:1.8; margin-bottom:1rem;">
            Scan Perks was built because independent venues were stuck between paper punch cards and $200/month enterprise software. We created a business loyalty program that's as simple as a QR scan and as affordable as $10/month.
          </p>
          <p style="color:var(--text-secondary); line-height:1.8;">
            Today we power loyalty for hundreds of bars, cafes, and restaurants — helping them grow loyal customers with digital rewards, push offers, and real-time analytics.
          </p>
        </div>
        <div class="glass glass--strong reveal" style="padding:2.5rem; text-align:center;">
          <div style="font-size:3rem; margin-bottom:1rem;">🚀</div>
          <h3 style="font-weight:800; margin-bottom:0.5rem;">Founded 2024</h3>
          <p style="color:var(--text-secondary);">Built for bars, cafes & restaurants.</p>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
